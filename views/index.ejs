<%- include("partials/head") %>

    <body>

        <%- include("partials/header") %>
            <%- include("partials/nav") %>

                <main class="container">

                    <h1>Welcome to CSE Motors!</h1>

                    <section class="hero">

                        <div class="hero-text">
                            <h2>DMC Delorean</h2>

                            <ul>
                                <li>3 Cup holders</li>
                                <li>Superman doors</li>
                                <li>Fuzzy dice</li>
                            </ul>

                            <button class="btn">Own Today</button>

                        </div>

                        <div class="hero-image">
                            <img src="/images/delorean1.png" alt="Delorean Car">
                        </div>

                    </section>

                    <section class="content">
  
                        <div class="upgrades">

                            <h3>Delorean Upgrades</h3>

                            <div class="upgrade-grid">

                                <div>
                                    <img src="/images/fluxcapacitor.webp" alt="Flux Capacitor">
                                    <p>Flux Capacitor</p>
                                </div>

                                <div>
                                    <img src="/images/flameicon.webp" alt="Flame Decals">
                                    <p>Flame Decals</p>
                                </div>

                                <div>
                                    <img src="/images/carbumper1.jpg" alt="Bumper Stickers">
                                    <p>Bumper Stickers</p>
                                </div>

                                <div>
                                    <img src="/images/carhubcap.webp" alt="Hub Caps">
                                    <p>Hub Caps</p>
                                </div>

                            </div>

                        </div>

                        <div class="reviews">

                            <h3>DMC Delorean Reviews</h3>

                            <ul>
                                <li>"So fast it's almost like traveling in time." (4/5)</li>
                                <li>"Coolest ride on the road." (4/5)</li>
                                <li>"I'm feeling McFly!" (5/5)</li>
                                <li>"The most futuristic ride of our day." (4.5/5)</li>
                                <li>"80's livin and I love it!" (5/5)</li>
                            </ul>

                        </div>

                    </section>

                </main>

                <%- include("partials/footer") %>

    </body>

    </html>